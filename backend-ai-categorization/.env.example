# InboxIQ Backend environment configuration
# Copy to .env and replace values as needed.

# App
ENVIRONMENT=development
APP_NAME=InboxIQ
API_BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/inboxiq

# Auth/JWT
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=15
REFRESH_TOKEN_EXP_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Encryption (Fernet key: `python -m cryptography.fernet` to generate)
ENCRYPTION_KEY=base64-fernet-key

# Sentry
SENTRY_DSN=

# Redis (rate limiting)
REDIS_URL=redis://localhost:6379/0

# Claude
CLAUDE_API_KEY=

# Gmail API
GMAIL_API_USER=me

# Digest
DEFAULT_DIGEST_FREQUENCY_HOURS=12
