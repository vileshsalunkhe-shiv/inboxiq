# InboxIQ Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=8000
ENVIRONMENT=development  # development, staging, production
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR, CRITICAL

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# Development:
DATABASE_URL=postgresql://inboxiq:inboxiq_dev_password@localhost:5432/inboxiq_dev
# Production (Railway auto-provides):
# DATABASE_URL=${{PostgreSQL.DATABASE_URL}}

# Connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false  # Set to true for SQL query logging

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis connection string
# Format: redis://[:password]@host:port/database
# Development:
REDIS_URL=redis://:inboxiq_redis_pass@localhost:6379/0
# Production (Railway auto-provides):
# REDIS_URL=${{Redis.REDIS_URL}}

# Redis settings
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Configuration
# Generate secret: openssl rand -base64 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Encryption Key for storing Gmail tokens
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-must-be-32-url-safe-base64-encoded-bytes

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://inboxiq.app
CORS_ALLOW_CREDENTIALS=true

# Security Headers
HSTS_MAX_AGE=31536000  # 1 year in seconds
HSTS_INCLUDE_SUBDOMAINS=true

# =============================================================================
# GOOGLE OAUTH CONFIGURATION
# =============================================================================
# Create credentials at: https://console.cloud.google.com/apis/credentials
# OAuth 2.0 Client ID for Web Application
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth redirect URI (must match Google Console configuration)
# Development:
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
# Production:
# GOOGLE_REDIRECT_URI=https://api.inboxiq.app/auth/callback

# Gmail API Scopes (space-separated)
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/gmail.send

# =============================================================================
# ANTHROPIC CLAUDE AI CONFIGURATION
# =============================================================================
# Get API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Model configuration
CLAUDE_MODEL=claude-3-haiku-20240307  # Fastest, cheapest for categorization
# Alternative models:
# claude-3-sonnet-20240229  # Better quality, slower, more expensive
# claude-3-opus-20240229    # Best quality, slowest, most expensive

CLAUDE_MAX_TOKENS=1024
CLAUDE_TEMPERATURE=0.3  # Lower = more consistent, higher = more creative
CLAUDE_TIMEOUT=30       # API timeout in seconds

# Cost tracking
CLAUDE_DAILY_BUDGET_USD=10.00
CLAUDE_COST_ALERT_THRESHOLD_USD=8.00

# =============================================================================
# APPLE PUSH NOTIFICATION SERVICE (APNs)
# =============================================================================
# For iOS push notifications
# Get these from Apple Developer Portal
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apple-team-id
APNS_BUNDLE_ID=com.yourcompany.inboxiq
APNS_KEY_PATH=/path/to/AuthKey_KEYID.p8

# APNs environment
APNS_USE_SANDBOX=true  # true for development, false for production

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Sentry Error Tracking
# Create project at: https://sentry.io/
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% of transactions
SENTRY_ENABLE_TRACING=true

# Logging Configuration
LOG_FORMAT=json  # json or text
LOG_FILE_PATH=/var/log/inboxiq/app.log  # Optional file logging
LOG_FILE_MAX_BYTES=10485760  # 10 MB
LOG_FILE_BACKUP_COUNT=5

# Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# =============================================================================
# RATE LIMITING
# =============================================================================
# Rate limits per user
RATE_LIMIT_SYNC_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=60
RATE_LIMIT_AI_PER_HOUR=1000

# Rate limits per IP (unauthenticated)
RATE_LIMIT_IP_PER_MINUTE=30

# Burst allowance
RATE_LIMIT_BURST_MULTIPLIER=2

# =============================================================================
# WORKER CONFIGURATION
# =============================================================================
# AI Worker settings
WORKER_CONCURRENCY=5           # Number of concurrent jobs
WORKER_BATCH_SIZE=10          # Emails processed per batch
WORKER_POLL_INTERVAL=5        # Seconds between queue checks
WORKER_MAX_RETRIES=3          # Retry failed jobs
WORKER_RETRY_DELAY=60         # Seconds between retries

# Digest Worker settings
DIGEST_ENABLED=true
DIGEST_CHECK_INTERVAL=3600    # Check every hour (in seconds)
DIGEST_DEFAULT_FREQUENCY=12   # Default: Every 12 hours
DIGEST_MIN_EMAIL_COUNT=5      # Skip digest if fewer emails

# =============================================================================
# EMAIL SYNC CONFIGURATION
# =============================================================================
# Sync settings
SYNC_INITIAL_EMAIL_COUNT=100   # Emails to fetch on first sync
SYNC_MAX_EMAILS_PER_REQUEST=500
SYNC_BATCH_SIZE=50
SYNC_TIMEOUT=300               # 5 minutes

# Sync labels (comma-separated)
SYNC_LABELS=INBOX,IMPORTANT,SENT

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features
FEATURE_DAILY_DIGEST=true
FEATURE_CUSTOM_CATEGORIES=true
FEATURE_EMAIL_SEARCH=true
FEATURE_BULK_OPERATIONS=true
FEATURE_ANALYTICS=false

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================
# Debug mode (NEVER enable in production!)
DEBUG=false
DEBUG_SQL=false
DEBUG_AI_PROMPTS=false

# Development tools
ENABLE_API_DOCS=true          # /docs and /redoc endpoints
ENABLE_PLAYGROUND=true        # API playground
RELOAD_ON_CHANGE=true         # Auto-reload on code changes

# =============================================================================
# BACKUP & MAINTENANCE
# =============================================================================
# Database backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *     # Daily at 2 AM (cron format)
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=inboxiq-backups

# Maintenance windows
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=InboxIQ is currently undergoing maintenance

# =============================================================================
# PRODUCTION CHECKLIST
# =============================================================================
# Before deploying to production, ensure:
# ✅ All secrets are strong and unique
# ✅ DEBUG=false
# ✅ LOG_LEVEL=INFO or WARNING
# ✅ ENVIRONMENT=production
# ✅ CORS_ORIGINS contains only your production domains
# ✅ SENTRY_DSN is configured
# ✅ Database backups are enabled
# ✅ SSL/TLS is configured
# ✅ Rate limiting is properly configured
# ✅ APNs production certificates are used
# ✅ All API keys are production keys (not test keys)
